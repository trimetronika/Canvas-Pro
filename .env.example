# CanvasPro - Required Environment Variables
# Copy this file to .env.local for local development

# Google Gemini API Key - Required for AI route generation
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Vercel KV Store - Auto-injected when you add a KV database in Vercel dashboard
# These are NOT needed for local dev (server.ts uses a local JSON file instead)
# KV_URL=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=
